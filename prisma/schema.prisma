generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // KOSONGKAN DI SINI. URL sudah ditarik otomatis dari prisma.config.ts
}

model Pengguna {
  id        Int         @id @default(autoincrement())
  nama      String      @default("Pengguna Baru")
  saldoAwal Int         @default(0)
  transaksi Transaksi[] 
}

model Transaksi {
  id         Int      @id @default(autoincrement())
  judul      String
  nominal    Int
  tipe       String
  tanggal    DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  penggunaId Int?     
  pengguna   Pengguna? @relation(fields: [penggunaId], references: [id])
}